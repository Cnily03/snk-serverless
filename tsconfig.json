{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "./worker-configuration.d.ts"],
    "paths": {
      "@/*": ["./src/*"],
      "@snk/*": ["./snk/packages/*"]
    }
  }
}
